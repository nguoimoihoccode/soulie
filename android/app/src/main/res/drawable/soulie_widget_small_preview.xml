<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="315"
                android:endColor="#120F17"
                android:startColor="#201628" />
        </shape>
    </item>
    <item android:gravity="top|start" android:left="14dp" android:top="14dp">
        <shape android:shape="rectangle">
            <corners android:radius="13dp" />
            <size android:width="78dp" android:height="24dp" />
            <solid android:color="#36000000" />
        </shape>
    </item>
    <item android:gravity="top|start" android:left="26dp" android:top="20dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <size android:width="34dp" android:height="4dp" />
            <solid android:color="#F2FFFFFF" />
        </shape>
    </item>
    <item android:gravity="top|start" android:left="26dp" android:top="28dp">
        <shape android:shape="rectangle">
            <corners android:radius="4dp" />
            <size android:width="20dp" android:height="4dp" />
            <solid android:color="#CCFFFFFF" />
        </shape>
    </item>
    <item android:gravity="top|end" android:right="14dp" android:top="14dp">
        <shape android:shape="rectangle">
            <corners android:radius="13dp" />
            <size android:width="34dp" android:height="24dp" />
            <solid android:color="#FF85A2" />
        </shape>
    </item>
    <item android:gravity="center" android:left="16dp" android:right="16dp" android:top="42dp" android:bottom="56dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient android:angle="315" android:startColor="#2A1D33" android:endColor="#6A3652" />
        </shape>
    </item>
    <item android:gravity="center" android:top="76dp">
        <inset
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:drawable="@drawable/soulie_preview_brand_mark" />
    </item>
    <item android:gravity="bottom|start" android:left="14dp" android:right="14dp" android:bottom="40dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <size android:height="20dp" />
            <solid android:color="#FFFFFFFF" />
        </shape>
    </item>
    <item android:gravity="bottom|start" android:left="14dp" android:right="70dp" android:bottom="18dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <size android:height="14dp" />
            <solid android:color="#D9FFFFFF" />
        </shape>
    </item>
    <item android:gravity="bottom|end" android:right="14dp" android:bottom="16dp">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <size android:width="44dp" android:height="20dp" />
            <solid android:color="#24FFFFFF" />
        </shape>
    </item>
</layer-list>
